async function cargarAudit(){
  const cat=document.getElementById('log-cat')?.value||'';
  const desde=document.getElementById('log-desde')?.value||'';
  const hasta=document.getElementById('log-hasta')?.value||'';

  let q=sb.from('audit_logs').select('*').order('creado_en',{ascending:false}).limit(100);
  if(cat)q=q.eq('categoria',cat);
  if(desde)q=q.gte('creado_en',desde+'T00:00:00');
  if(hasta)q=q.lte('creado_en',hasta+'T23:59:59');
  const{data:logs}=await q;

  // Stats
  const hoy=new Date().toLocaleDateString('es-DO');
  const logsHoy=logs?.filter(l=>new Date(l.creado_en).toLocaleDateString('es-DO')===hoy)||[];
  const loginsHoy=logsHoy.filter(l=>l.accion?.includes('Login'));
  const fallidos=logsHoy.filter(l=>l.accion?.includes('fallido'));
  document.getElementById('sg-hoy').textContent=logsHoy.length;
  document.getElementById('sg-logins').textContent=loginsHoy.length;
  document.getElementById('sg-fallidos').textContent=fallidos.length;

  // 2FA count
  const{count:mfaCount}=await sb.from('perfiles').select('*',{count:'exact',head:true}).eq('mfa_habilitado',true);
  document.getElementById('sg-2fa').textContent=mfaCount||0;

  // Sesiones
  const{data:ses}=await sb.from('sesiones').select('*').order('creado_en',{ascending:false}).limit(20);
  document.getElementById('sg-sesiones').textContent=ses?.filter(s=>s.activa).length||0;
  if(ses?.length){
    document.getElementById('t-sesiones').querySelector('tbody').innerHTML=ses.map(s=>{
      const ua=s.user_agent||'';
      const device=ua.includes('Mobile')?'📱 Móvil':'🖥️ Desktop';
      const browser=ua.includes('Chrome')?'Chrome':ua.includes('Firefox')?'Firefox':ua.includes('Safari')?'Safari':'Otro';
      return`<tr><td>${s.email||'—'}</td><td>${device} ${browser}</td><td>${new Date(s.creado_en).toLocaleString('es-DO')}</td><td>${s.activa?'<span class="badge green">Activa</span>':'<span class="badge red">Cerrada</span>'}</td></tr>`;
    }).join('');
  }

  // Tabla logs
  if(!logs?.length){tbEmpty('t-audit',5);} else {
    document.getElementById('t-audit').querySelector('tbody').innerHTML=logs.map(l=>{
      const catColor={'auth':'blue','clientes':'green','facturas':'gold','pagos':'green','inversiones':'purple','fondo':'purple','config':'red','perfil':'blue'};
      return`<tr><td style="white-space:nowrap;font-size:11px">${new Date(l.creado_en).toLocaleString('es-DO')}</td><td>${l.email||'—'}</td><td>${l.accion}</td><td>${bdg(l.categoria)}</td><td style="color:var(--muted);font-size:11px">${l.detalle||'—'}</td></tr>`;
    }).join('');
  }

  // Gráfica actividad 7 días
  renderChartAudit(logs||[]);
}

function renderChartAudit(logs){
  const ctx=document.getElementById('chart-audit');if(!ctx)return;
  if(chartAudit)chartAudit.destroy();
  const dias=[],datos=[];
  for(let i=6;i>=0;i--){
    const d=new Date();d.setDate(d.getDate()-i);
    const key=d.toLocaleDateString('es-DO');
    dias.push(d.toLocaleDateString('es-DO',{weekday:'short',day:'numeric'}));
    datos.push(logs.filter(l=>new Date(l.creado_en).toLocaleDateString('es-DO')===key).length);
  }
  chartAudit=new Chart(ctx,{type:'bar',data:{labels:dias,datasets:[{label:'Eventos',data:datos,backgroundColor:'rgba(59,130,246,0.6)',borderRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#a0a8bc',font:{size:10}}}},scales:{x:{ticks:{color:'#7b849a'},grid:{color:'rgba(255,255,255,0.05)'}},y:{ticks:{color:'#7b849a',stepSize:1},grid:{color:'rgba(255,255,255,0.05)'}}}}});
}

