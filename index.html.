<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Avanch App</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
:root{--bg:#07090e;--bg2:#0d1017;--bg3:#131720;--surface:#191e2a;--surface2:#1f2635;--border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.12);--text:#eceef8;--muted:#7b849a;--muted2:#a0a8bc;--blue:#2563eb;--blue2:#3b82f6;--blue3:#60a5fa;--green:#059669;--green2:#10b981;--green3:#34d399;--gold:#d97706;--gold3:#fbbf24;--red:#dc2626;--red2:#ef4444;--purple:#7c3aed;--purple3:#a78bfa;--ff:'DM Sans',system-ui,sans-serif;--ff2:'Syne',system-ui,sans-serif}
*{box-sizing:border-box;margin:0;padding:0}html,body{height:100%;font-family:var(--ff);background:var(--bg);color:var(--text);font-size:13px}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.auth-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;position:relative;overflow:hidden}
.auth-screen::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(37,99,235,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(37,99,235,.03) 1px,transparent 1px);background-size:48px 48px;pointer-events:none}
.auth-orb{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none}
.orb1{width:500px;height:400px;background:rgba(37,99,235,.08);top:-100px;left:50%;transform:translateX(-50%)}
.orb2{width:300px;height:300px;background:rgba(124,58,237,.05);bottom:0;right:5%}
.auth-box{background:var(--bg2);border:1px solid var(--border2);border-radius:20px;padding:36px;width:100%;max-width:420px;position:relative;z-index:1;animation:fadeUp .5s ease}
.auth-mark{width:40px;height:40px;background:linear-gradient(135deg,var(--blue),var(--purple));border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:var(--ff2);font-weight:800;font-size:14px;color:#fff;box-shadow:0 0 20px rgba(37,99,235,.3);margin:0 auto 10px}
.auth-title{font-family:var(--ff2);font-size:22px;font-weight:800;text-align:center;margin-bottom:6px}
.auth-sub{font-size:12px;color:var(--muted);text-align:center;margin-bottom:24px}
.auth-tabs{display:flex;gap:4px;background:var(--surface);border-radius:10px;padding:4px;margin-bottom:20px}
.auth-tab{flex:1;text-align:center;padding:8px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:600;color:var(--muted);transition:all .2s}
.auth-tab.active{background:var(--blue);color:#fff}
.fg{margin-bottom:12px}.fg label{display:block;font-size:11px;color:var(--muted);margin-bottom:4px;font-weight:500}
.fg input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:13px;font-family:var(--ff);outline:none;transition:border-color .2s}
.fg input:focus{border-color:var(--blue2)}
.btn-auth{width:100%;background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;border:none;border-radius:10px;padding:12px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--ff2);margin-top:4px;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.btn-auth:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(37,99,235,.3)}
.btn-auth:disabled{opacity:.6;cursor:not-allowed;transform:none}
.auth-error{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--red2);margin-bottom:12px;display:none}
.auth-error.show{display:block}
.app-shell{display:none;grid-template-rows:56px 1fr;height:100vh}
.app-shell.visible{display:grid}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:0 20px;background:var(--bg2);border-bottom:1px solid var(--border)}
.tb-left{display:flex;align-items:center;gap:10px}
.tb-mark{width:30px;height:30px;background:linear-gradient(135deg,var(--blue),var(--purple));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--ff2);font-weight:800;font-size:11px;color:#fff}
.tb-name{font-family:var(--ff2);font-weight:700;font-size:14px}
.tb-name span{color:var(--muted);font-size:10px;font-weight:400;margin-left:6px}
.tb-right{display:flex;align-items:center;gap:10px}
.tb-user{font-size:11px;color:var(--muted2);background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:4px 10px;display:flex;align-items:center;gap:6px}
.tb-dot{width:6px;height:6px;background:var(--green3);border-radius:50%;animation:pulse 2s infinite}
.tb-logout{background:none;border:1px solid var(--border);border-radius:6px;padding:5px 10px;color:var(--muted);cursor:pointer;font-size:11px;font-family:var(--ff);transition:all .2s}
.tb-logout:hover{border-color:var(--red2);color:var(--red2)}
.tb-link{text-decoration:none;color:inherit;display:flex;align-items:center;gap:10px;transition:opacity .2s}
.tb-link:hover{opacity:.8}
.main{display:grid;grid-template-columns:196px 1fr;overflow:hidden}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);overflow-y:auto;padding:12px 0}
.nav-lbl{font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;padding:10px 16px 4px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 16px;cursor:pointer;transition:all .2s;border-left:2px solid transparent;color:var(--muted2);font-size:12px;font-weight:500}
.nav-item:hover{background:var(--surface);color:var(--text)}
.nav-item.active{background:rgba(37,99,235,.1);color:var(--blue3);border-left-color:var(--blue)}
.nav-icon{font-size:13px;width:16px;text-align:center}
.content{overflow-y:auto;padding:20px}
.tab-panel{display:none}.tab-panel.active{display:block}
.sec-title{font-family:var(--ff2);font-size:13px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:8px}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border)}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:18px}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px}
.sc-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
.sc-val{font-family:var(--ff2);font-size:19px;font-weight:700;margin-bottom:2px}
.sc-sub{font-size:10px;color:var(--muted)}
.sc.blue .sc-val{color:var(--blue3)}.sc.green .sc-val{color:var(--green3)}.sc.gold .sc-val{color:var(--gold3)}.sc.purple .sc-val{color:var(--purple3)}.sc.red .sc-val{color:var(--red2)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:14px}
.card-title{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.dt{width:100%;border-collapse:collapse}
.dt th{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;padding:8px 12px;border-bottom:1px solid var(--border);text-align:left}
.dt td{padding:10px 12px;border-bottom:1px solid var(--border);font-size:12px}
.dt tr:last-child td{border-bottom:none}
.dt tr:hover td{background:rgba(255,255,255,.02)}
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600}
.badge.green{background:rgba(16,185,129,.15);color:var(--green3);border:1px solid rgba(16,185,129,.2)}
.badge.gold{background:rgba(251,191,36,.12);color:var(--gold3);border:1px solid rgba(251,191,36,.2)}
.badge.red{background:rgba(239,68,68,.12);color:var(--red2);border:1px solid rgba(239,68,68,.2)}
.badge.blue{background:rgba(96,165,250,.12);color:var(--blue3);border:1px solid rgba(96,165,250,.2)}
.badge.purple{background:rgba(167,139,250,.12);color:var(--purple3);border:1px solid rgba(167,139,250,.2)}
.fgg{margin-bottom:11px}.fgg label{display:block;font-size:11px;color:var(--muted);margin-bottom:4px;font-weight:500}
.fgg input,.fgg select,.fgg textarea{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:7px;padding:8px 11px;color:var(--text);font-size:12px;font-family:var(--ff);outline:none;transition:border-color .2s}
.fgg input:focus,.fgg select:focus,.fgg textarea:focus{border-color:var(--blue2)}
.fgg select option{background:var(--bg3)}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn{border:none;border-radius:7px;padding:8px 16px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--ff);transition:all .2s;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:var(--blue);color:#fff}.btn-primary:hover{background:#1d4ed8}
.btn-green{background:var(--green);color:#fff}.btn-green:hover{background:#047857}
.btn-ghost{background:var(--surface2);color:var(--muted2);border:1px solid var(--border)}.btn-ghost:hover{color:var(--text);border-color:var(--border2)}
.btn-gold{background:var(--gold);color:#fff}.btn-gold:hover{background:#b45309}
.btn-red{background:var(--red);color:#fff}.btn-red:hover{background:#b91c1c}
.alert{border-radius:8px;padding:11px 14px;font-size:12px;margin-bottom:12px}
.alert.info{background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.2);color:var(--blue3)}
.alert.warn{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.2);color:var(--gold3)}
.loader{display:flex;align-items:center;justify-content:center;padding:36px;color:var(--muted);flex-direction:column;gap:10px}
.spin{width:22px;height:22px;border:2px solid var(--border2);border-top-color:var(--blue3);border-radius:50%;animation:spin .7s linear infinite}
.notif{position:fixed;bottom:20px;right:20px;background:var(--surface);border:1px solid var(--border2);border-radius:10px;padding:10px 16px;font-size:12px;color:var(--text);z-index:999;opacity:0;transform:translateY(8px);transition:all .3s;box-shadow:0 8px 24px rgba(0,0,0,.4);pointer-events:none}
.notif.show{opacity:1;transform:translateY(0)}.notif.ok{border-left:3px solid var(--green3)}.notif.err{border-left:3px solid var(--red2)}
.inv-hero{background:linear-gradient(135deg,rgba(37,99,235,.1),rgba(124,58,237,.08));border:1px solid rgba(37,99,235,.2);border-radius:16px;padding:24px;margin-bottom:18px}
.inv-hero-title{font-family:var(--ff2);font-size:18px;font-weight:800;margin-bottom:6px}
.inv-hero-sub{font-size:12px;color:var(--muted2);line-height:1.6;margin-bottom:16px}
.isr{background:rgba(37,99,235,.07);border:1px solid rgba(37,99,235,.18);border-radius:9px;padding:13px;margin-top:10px}
.isr-row{display:flex;justify-content:space-between;margin-bottom:5px;font-size:12px}
.isr-row .l{color:var(--muted)}.isr-row .v{color:var(--text);font-weight:600}
.isr-total{display:flex;justify-content:space-between;padding-top:8px;border-top:1px solid var(--border);margin-top:6px}
.isr-total .l{font-weight:600}.isr-total .v{font-family:var(--ff2);font-size:15px;font-weight:700;color:var(--green3)}
.chart-container{position:relative;width:100%;height:260px;margin-top:8px}
.rules-list{display:flex;flex-direction:column;gap:8px}
.rule-item{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg3);border-radius:8px;border:1px solid var(--border)}
.rule-item .rl{font-size:12px;color:var(--muted2)}.rule-item .rv{font-family:var(--ff2);font-weight:700;font-size:14px}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;padding:24px;width:100%;max-width:520px;animation:fadeUp .3s ease;max-height:90vh;overflow-y:auto}
.modal-title{font-family:var(--ff2);font-size:14px;font-weight:700;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center}
.modal-close{background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;line-height:1}
.modal-close:hover{color:var(--text)}
@media(max-width:640px){.main{grid-template-columns:1fr}.sidebar{display:none}.fg-row{grid-template-columns:1fr}.g2{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- AUTH -->
<div class="auth-screen" id="auth-screen">
  <div class="auth-orb orb1"></div><div class="auth-orb orb2"></div>
  <div class="auth-box">
    <div class="auth-mark">AT</div>
    <div class="auth-title">Avanch App</div>
    <div class="auth-sub">Portal de facturación, clientes e inversión</div>
    <div class="auth-tabs">
      <div class="auth-tab active" id="tab-login" onclick="switchAuth('login')">Iniciar sesión</div>
      <div class="auth-tab" id="tab-register" onclick="switchAuth('register')">Registrarse</div>
    </div>
    <div class="auth-error" id="auth-error"></div>
    <div id="form-login">
      <div class="fg"><label>Correo electrónico</label><input type="email" id="login-email" placeholder="correo@empresa.com" onkeypress="if(event.key==='Enter')doLogin()"></div>
      <div class="fg"><label>Contraseña</label><input type="password" id="login-password" placeholder="Tu contraseña" onkeypress="if(event.key==='Enter')doLogin()"></div>
      <button class="btn-auth" onclick="doLogin()" id="btn-login">Iniciar sesión</button>
      <div style="text-align:center;margin-top:12px;font-size:11px;color:var(--muted)">¿Olvidaste tu contraseña? <span style="color:var(--blue3);cursor:pointer" onclick="doReset()">Restablecer</span></div>
    </div>

<div id="form-mfa" style="display:none">
  <div style="text-align:center;margin-bottom:16px"><div style="font-size:36px;margin-bottom:8px">🔐</div><div style="font-family:var(--ff2);font-size:15px;font-weight:700;margin-bottom:4px">Verificación 2FA</div><div style="font-size:11px;color:var(--muted)">Ingresa el código de 6 dígitos de tu app de autenticación</div></div>
  <div class="fg"><label>Código TOTP</label><input type="text" id="mfa-login-code" placeholder="000000" maxlength="6" style="text-align:center;font-size:24px;letter-spacing:12px;font-family:var(--ff2);font-weight:700" onkeypress="if(event.key==='Enter')verificarMFALogin()"></div>
  <button class="btn-auth" onclick="verificarMFALogin()" id="btn-mfa-verify">🔓 Verificar</button>
  <div style="text-align:center;margin-top:12px"><span style="color:var(--muted);font-size:11px;cursor:pointer" onclick="cancelarMFA()">← Volver al login</span></div>
</div>
    
    <div id="form-register" style="display:none">
      <div class="fg"><label>Nombre completo</label><input type="text" id="reg-nombre" placeholder="Tu nombre o razón social"></div>
      <div class="fg"><label>Correo electrónico</label><input type="email" id="reg-email" placeholder="correo@empresa.com"></div>
      <div class="fg"><label>Contraseña</label><input type="password" id="reg-password" placeholder="Mínimo 8 caracteres"></div>
      <div class="fg"><label>Teléfono</label><input type="tel" id="reg-tel" placeholder="809-000-0000"></div>
      <button class="btn-auth" onclick="doRegister()" id="btn-register">Crear cuenta</button>
    </div>
    <div style="text-align:center;margin-top:16px;font-size:11px;color:var(--muted)">Avanch Technology SRL · Santo Domingo Este, RD</div>
  </div>
</div>

<!-- MODAL EDITAR CLIENTE -->
<div class="modal-overlay" id="modal-edit-cliente">
  <div class="modal">
    <div class="modal-title">✏️ Editar Cliente <button class="modal-close" onclick="cerrarModal()">✕</button></div>

<!-- MODAL CONTRATO -->
<div class="modal-overlay" id="modal-contrato">
  <div class="modal" style="max-width:640px">
    <div class="modal-title">📄 Contrato de Inversión <button class="modal-close" onclick="cerrarContrato()">✕</button></div>
    <div id="contrato-body" style="background:var(--bg3);border-radius:10px;padding:20px;font-size:12px;line-height:1.8;max-height:400px;overflow-y:auto;margin-bottom:14px;border:1px solid var(--border)"></div>
    <div id="contrato-firma" style="display:none">
      <div class="alert warn">⚠️ Al firmar este contrato, aceptas los términos descritos. Esta acción es irreversible.</div>
      <div class="fgg"><label>Nombre completo (firma digital)</label><input type="text" id="firma-nombre" placeholder="Escribe tu nombre completo"></div>
      <button class="btn btn-green" onclick="firmarContrato()">✍️ Firmar contrato</button>
    </div>
    <div id="contrato-firmado" style="display:none">
      <div style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);border-radius:8px;padding:12px;color:var(--green3);font-size:12px">✅ Contrato firmado digitalmente</div>
    </div>
    <div style="display:flex;gap:8px;margin-top:10px">
      <button class="btn btn-primary" onclick="imprimirContrato()">🖨️ Imprimir</button>
      <button class="btn btn-ghost" onclick="cerrarContrato()">Cerrar</button>
    </div>
  </div>
</div>
    <input type="hidden" id="ec-id">
    <div class="fg-row">
      <div class="fgg"><label>Nombre *</label><input type="text" id="ec-nombre"></div>
      <div class="fgg"><label>RNC</label><input type="text" id="ec-rnc"></div>
    </div>
    <div class="fg-row">
      <div class="fgg"><label>Email</label><input type="email" id="ec-email"></div>
      <div class="fgg"><label>Teléfono</label><input type="tel" id="ec-tel"></div>
    </div>
    <div class="fgg"><label>Dirección</label><input type="text" id="ec-dir"></div>
    <div class="fg-row">
      <div class="fgg"><label>Plan</label><select id="ec-plan"><option>Plan Iniciado — RD$1,500/mes</option><option>Plan Experto — RD$2,500/mes</option><option>Plan Grande PYMES — RD$3,500/mes</option></select></div>
      <div class="fgg"><label>Día ciclo</label><select id="ec-ciclo"><option value="3">3</option><option value="5">5</option><option value="10">10</option><option value="20">20</option><option value="25">25</option></select></div>
    </div>
    <div class="fgg"><label>Estado</label><select id="ec-estado"><option value="activo">Activo</option><option value="inactivo">Inactivo</option><option value="suspendido">Suspendido</option></select></div>
    <div style="display:flex;gap:8px;margin-top:4px">
      <button class="btn btn-green" onclick="guardarEdicionCliente()">✓ Guardar</button>
      <button class="btn btn-ghost" onclick="cerrarModal()">Cancelar</button>
    </div>
  </div>
</div>

<!-- APP -->
<div class="app-shell" id="app-shell">
  <div class="topbar">
    <div class="tb-left">
      <div style="display:flex;align-items:center;gap:10px">
        <div class="tb-mark">AT</div>
        <div class="tb-name">Avanch App <span id="tb-rol"></span></div>
      </div>
    </div>
    <div class="tb-right">
      <div class="tb-user"><div class="tb-dot"></div><span id="tb-user">—</span></div>
      <button class="tb-logout" onclick="doLogout()">Salir</button>
    </div>
  </div>
  <div class="main">
    <div class="sidebar" id="sidebar"></div>
    <div class="content" id="content">

      <!-- INICIO / DASHBOARD -->
      <div class="tab-panel active" id="tab-inicio">
        <div class="sec-title">📊 Dashboard Financiero</div>
        <div class="stats-grid" id="stats-inicio"><div class="loader"><div class="spin"></div></div></div>

        <!-- ADMIN DASHBOARD -->
        <div id="dash-admin" style="display:none">
          <!-- SECCIÓN: INGRESOS POR SERVICIOS -->
          <div style="font-family:var(--ff2);font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;margin-top:4px">📊 Ingresos por servicios (facturación)</div>
          <div class="g2">
            <div class="card">
              <div class="card-title">📈 Ingresos mensuales — Servicios</div>
              <div class="chart-container"><canvas id="chart-ingresos"></canvas></div>
            </div>
            <div class="card">
              <div class="card-title">🥧 Distribución por modelo</div>
              <div class="chart-container"><canvas id="chart-modelos"></canvas></div>
            </div>
          </div>
          <div class="g2">
            <div class="card">
              <div class="card-title">💰 Flujo: Avanch / Komultisoft / VicOrtiz</div>
              <div class="chart-container"><canvas id="chart-flujo"></canvas></div>
            </div>
            <div class="card">
              <div class="card-title">🏆 Top clientes por facturación</div>
              <div style="overflow-x:auto"><table class="dt" id="t-top-clientes"><thead><tr><th>Cliente</th><th>Facturado</th><th>Pagado</th><th>Pendiente</th></tr></thead><tbody><tr><td colspan="4"><div class="loader"><div class="spin"></div></div></td></tr></tbody></table></div>
            </div>
