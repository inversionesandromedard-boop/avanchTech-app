// ═══ UTILIDADES ═══
function tog(id){const e=document.getElementById(id);e.style.display=e.style.display==='none'?'block':'none';}
function tbEmpty(id,cols){document.getElementById(id).querySelector('tbody').innerHTML=`<tr><td colspan="${cols}" style="text-align:center;color:var(--muted);padding:18px">Sin registros</td></tr>`;}
function bdg(e){const m={activo:'green',pagada:'green',pagado:'green',confirmado:'green',entregado:'green',convertido:'green',aprobada:'green',firmado:'green',inversion:'purple',cliente:'blue',inversionista:'purple',pendiente:'gold',nuevo:'gold',deposito:'green',ganancia:'green',retiro:'red',comision:'purple',enviado:'blue',contactado:'blue',inactivo:'red',vencida:'red',cancelada:'red',rechazada:'red',suspendido:'red',suspendida:'red',tecnologia:'blue',servicio:'purple',accesorio:'gold',software:'blue',otro:'blue',descontinuado:'red'};return`<span class="badge ${m[e]||'blue'}">${e||'—'}</span>`;}
function fmt(n){return parseFloat(n||0).toLocaleString('es-DO',{minimumFractionDigits:2,maximumFractionDigits:2});}
function notif(m,t){const n=document.getElementById('notif');n.textContent=m;n.className='notif '+(t||'ok')+' show';setTimeout(()=>n.classList.remove('show'),3000);}
</script>
