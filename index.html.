async function ajustarStock(id,nombre,stockActual){
  const input=prompt('Stock actual de "'+nombre+'": '+stockActual+'\n\nEscribe el nuevo stock (o +N / -N para ajustar):');
  if(input===null||input.trim()==='')return;
  let nuevoStock;const v=input.trim();
  if(v.startsWith('+')||v.startsWith('-'))nuevoStock=stockActual+parseInt(v);
  else nuevoStock=parseInt(v);
  if(isNaN(nuevoStock)||nuevoStock<0){notif('⚠️ Valor inválido','err');return;}
  const diff=nuevoStock-stockActual;
  await sb.from('productos').update({stock:nuevoStock}).eq('id',id);
  await sb.from('movimientos_stock').insert({producto_id:id,tipo:diff>0?'entrada':diff<0?'salida':'ajuste',cantidad:Math.abs(diff),stock_resultante:nuevoStock,detalle:'Ajuste manual: '+stockActual+' → '+nuevoStock});
  notif('✓ Stock "'+nombre+'": '+nuevoStock,'ok');cargarInventario();
  registrarLog('Stock ajustado','inventario',nombre+': '+stockActual+' → '+nuevoStock,'productos',id);
}

