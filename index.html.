  const ext=file.name.split('.').pop().toLowerCase();
  const nombre='prod_'+Date.now()+'_'+Math.random().toString(36).slice(2,8)+'.'+ext;

  const{data,error}=await sb.storage.from(STORAGE_BUCKET).upload(nombre,file,{
    cacheControl:'3600',upsert:false,contentType:file.type
  });

  if(error){
    // Si bucket no existe, intentar crear y reintentar
    if(error.message?.includes('not found')||error.statusCode==='404'){
      status.innerHTML='<span style="color:var(--gold3)">⚠️ Creando bucket... (configura "productos" en Storage de Supabase como público)</span>';
