// ═══ ADMIN: GESTIÓN DE INVERSIONISTAS ═══
async function editarInversion(id){
  const{data:inv}=await sb.from('inversiones').select('*,perfiles(nombre,email)').eq('id',id).single();
  if(!inv){notif('No encontrada','err');return;}
  const nuevoMonto=prompt('Monto actual: RD$'+fmt(inv.monto)+'\nNuevo monto (dejar vacío para no cambiar):');
  const nuevoPlazo=prompt('Plazo actual: '+inv.plazo_meses+'m\nNuevo plazo en meses (dejar vacío para no cambiar):');
  const datos={};
  if(nuevoMonto&&!isNaN(parseFloat(nuevoMonto)))datos.monto=parseFloat(nuevoMonto);
  if(nuevoPlazo&&!isNaN(parseInt(nuevoPlazo)))datos.plazo_meses=parseInt(nuevoPlazo);
  if(!Object.keys(datos).length){notif('Sin cambios','ok');return;}
  const{error}=await sb.from('inversiones').update(datos).eq('id',id);
  if(error){notif('Error: '+error.message,'err');return;}
  notif('✓ Inversión actualizada','ok');cargarFondo();
  registrarLog('Inversión editada','inversiones','ID: '+id+' — Cambios: '+JSON.stringify(datos),'inversiones',id);
}

async function suspenderInversionista(perfilId,nombre){
  if(!confirm('¿Suspender al inversionista "'+nombre+'"?\n\nNo podrá invertir ni generar nuevas operaciones.\nSu historial se mantiene intacto.')){return;}
  const{error}=await sb.from('perfiles').update({estado:'suspendido'}).eq('id',perfilId);
  if(error){notif('Error: '+error.message,'err');return;}
  // Suspender inversiones pendientes
  await sb.from('inversiones').update({estado:'suspendida'}).eq('perfil_id',perfilId).eq('estado','pendiente');
  notif('⛔ Inversionista "'+nombre+'" suspendido','ok');cargarFondo();
  registrarLog('Inversionista suspendido','inversiones','Inversionista: '+nombre+' suspendido','perfiles',perfilId);
}

async function reactivarInversionista(perfilId,nombre){
  if(!confirm('¿Reactivar al inversionista "'+nombre+'"?')){return;}
