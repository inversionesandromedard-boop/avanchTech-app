async function cargarMFAStatus(){
  const mfaEl=document.getElementById('mfa-status');
  if(!mfaEl)return;
  try{
    const{data}=await sb.auth.mfa.listFactors();
    const totp=data?.totp||[];
    const activo=totp.some(f=>f.status==='verified');
    if(activo){
      mfaEl.innerHTML=`<div class="alert success" style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);color:var(--green3)">✅ 2FA activo — tu cuenta está protegida con autenticación de dos factores.</div><button class="btn btn-red" style="margin-top:8px" onclick="desactivarMFA()">Desactivar 2FA</button>`;
      document.getElementById('mfa-setup').style.display='none';
    } else {
      mfaEl.innerHTML=`<div class="alert warn">⚠️ 2FA no está activo. Te recomendamos activarlo para proteger tu cuenta.</div><button class="btn btn-primary" style="margin-top:8px" onclick="iniciarMFA()">Activar 2FA</button>`;
    }
  }catch(e){
    mfaEl.innerHTML=`<div class="alert info">ℹ️ Verificación de dos factores disponible.</div><button class="btn btn-primary" style="margin-top:8px" onclick="iniciarMFA()">Activar 2FA</button>`;
  }
}

async function iniciarMFA(){
  try{
    const{data,error}=await sb.auth.mfa.enroll({factorType:'totp',friendlyName:'Avanch App'});
    if(error){notif('Error al configurar 2FA: '+error.message,'err');return;}
    document.getElementById('mfa-setup').style.display='block';
    document.getElementById('mfa-qr').src=data.totp.qr_code;
    window._mfaFactorId=data.id;
  }catch(e){notif('Error: '+e.message,'err');}
}

async function verificarMFA(){
  const code=document.getElementById('mfa-code').value.trim();
  if(code.length!==6){notif('⚠️ Ingresa el código de 6 dígitos','err');return;}
  try{
    const{data:challenge}=await sb.auth.mfa.challenge({factorId:window._mfaFactorId});
    const{error}=await sb.auth.mfa.verify({factorId:window._mfaFactorId,challengeId:challenge.id,code});
    if(error){notif('Código incorrecto','err');return;}
    await sb.from('perfiles').update({mfa_habilitado:true}).eq('id',usr.id);
    notif('✅ 2FA activado correctamente','ok');
    registrarLog('2FA activado','auth','Autenticación de dos factores habilitada');
    cargarMFAStatus();
  }catch(e){notif('Error: '+e.message,'err');}
}

async function desactivarMFA(){
  try{
    const{data}=await sb.auth.mfa.listFactors();
    const totp=data?.totp||[];
    for(const f of totp){await sb.auth.mfa.unenroll({factorId:f.id});}
    await sb.from('perfiles').update({mfa_habilitado:false}).eq('id',usr.id);
    notif('2FA desactivado','ok');
    registrarLog('2FA desactivado','auth','Autenticación de dos factores deshabilitada');
    cargarMFAStatus();
