// ═══ ADMIN: FONDO ═══
async function cargarFondo(){
  const{data:inv}=await sb.from('inversiones').select('*,perfiles(id,nombre,email,estado)').order('fecha_solicitud',{ascending:false});
  if(!inv){tbEmpty('t-todas-inversiones',7);tbEmpty('t-inversionistas',6);return;}
  const fc=fondoConfig,activas=inv.filter(i=>i.estado==='aprobada'),pend=inv.filter(i=>i.estado==='pendiente');
  const cap=activas.reduce((a,i)=>a+parseFloat(i.monto||0),0);
  const gaAv=activas.reduce((a,i)=>a+parseFloat(i.monto||0)*(fc.spread_avanch/100/12)*parseInt(i.plazo_meses||6),0);
  const pagInv=activas.reduce((a,i)=>a+parseFloat(i.ganancia_acumulada||0),0);
  document.getElementById('fd-capital').textContent='RD$'+fmt(cap);
  document.getElementById('fd-ganancia-av').textContent='RD$'+fmt(gaAv);
  document.getElementById('fd-pagado').textContent='RD$'+fmt(pagInv);
  document.getElementById('fd-activas').textContent=activas.length;
  document.getElementById('fd-pend').textContent=pend.length;

  // Tabla de inversiones con acciones completas
  document.getElementById('t-todas-inversiones').querySelector('tbody').innerHTML=inv.map(i=>{
    const gi=parseFloat(i.monto||0)*(fc.tasa_inversionista_anual/100/12)*parseInt(i.plazo_meses||6);
    const ga=parseFloat(i.monto||0)*(fc.spread_avanch/100/12)*parseInt(i.plazo_meses||6);
    let acc='';
    if(i.estado==='pendiente'){
      acc+=`<button class="btn btn-green" style="padding:3px 8px;font-size:10px" onclick="aprobarInversion('${i.id}')" title="Aprobar">✓</button> `;
      acc+=`<button class="btn btn-red" style="padding:3px 8px;font-size:10px" onclick="rechazarInversion('${i.id}')" title="Rechazar">✕</button> `;
    }
    if(i.estado==='aprobada'){
      acc+=`<button class="btn btn-gold" style="padding:3px 8px;font-size:10px" onclick="editarInversion('${i.id}')" title="Editar">✏️</button> `;
    }
    if(!acc)acc='—';
    return`<tr><td>${i.perfiles?.nombre||'—'}</td><td style="color:var(--green3)">RD$${fmt(i.monto)}</td><td>${i.plazo_meses||'—'}m</td><td style="color:var(--gold3)">RD$${fmt(Math.min(gi,fc.techo_ganancia))}</td><td style="color:var(--purple3)">RD$${fmt(ga)}</td><td>${bdg(i.estado)}</td><td style="white-space:nowrap">${acc}</td></tr>`;
  }).join('');

  // Tabla de inversionistas (agrupado por perfil)
  const inversionistas={};
  inv.forEach(i=>{
    if(!i.perfiles)return;
    const pid=i.perfiles.id||i.perfil_id;
    if(!inversionistas[pid]){
      inversionistas[pid]={nombre:i.perfiles.nombre||'—',email:i.perfiles.email||'—',estado:i.perfiles.estado||'activo',total:0,count:0,perfilId:pid};
    }
    if(i.estado==='aprobada'){
      inversionistas[pid].total+=parseFloat(i.monto||0);
      inversionistas[pid].count++;
    }
  });
  const listaInv=Object.values(inversionistas);
  if(!listaInv.length){tbEmpty('t-inversionistas',6);}
  else{
    document.getElementById('t-inversionistas').querySelector('tbody').innerHTML=listaInv.map(p=>{
      const esSuspendido=p.estado==='suspendido';
      let acciones=`<button class="btn btn-gold" style="padding:3px 8px;font-size:10px" onclick="editarInversion('${p.perfilId}')" title="Ver inversiones">👁️</button> `;
      if(esSuspendido){
        acciones+=`<button class="btn btn-green" style="padding:3px 8px;font-size:10px" onclick="reactivarInversionista('${p.perfilId}','${p.nombre.replace(/'/g,"\\'")}')">✓ Reactivar</button>`;
      } else {
        acciones+=`<button class="btn btn-red" style="padding:3px 8px;font-size:10px" onclick="suspenderInversionista('${p.perfilId}','${p.nombre.replace(/'/g,"\\'")}')">⛔ Suspender</button>`;
      }
      return`<tr><td style="font-weight:600">${p.nombre}</td><td style="font-size:11px;color:var(--muted)">${p.email}</td><td>${p.count}</td><td style="color:var(--green3)">RD$${fmt(p.total)}</td><td>${bdg(p.estado)}</td><td style="white-space:nowrap">${acciones}</td></tr>`;
    }).join('');
  }

  renderChartFondoBarras(activas);renderChartFondoPastel(activas,cap);
}

async function aprobarInversion(id){
  const{data:inv}=await sb.from('inversiones').select('*,perfiles(nombre,email,rnc)').eq('id',id).single();if(!inv)return;
  const fi=new Date(),fv=new Date();fv.setMonth(fv.getMonth()+parseInt(inv.plazo_meses||6));
  const{error}=await sb.from('inversiones').update({estado:'aprobada',fecha_inicio:fi.toISOString(),fecha_vencimiento:fv.toISOString(),tasa_aplicada:calcTasaInversionista()}).eq('id',id);
  if(error){notif('Error: '+error.message,'err');return;}
  await sb.from('movimientos_fondo').insert({inversion_id:id,perfil_id:inv.perfil_id,tipo:'deposito',monto:inv.monto,descripcion:'Inversión aprobada — '+inv.proposito});
  // Generar contrato automáticamente
  await generarContrato(inv,fi,fv);
  notif('✓ Aprobada + contrato generado','ok');cargarFondo();
