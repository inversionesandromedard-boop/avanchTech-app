  let filtrados=_productosCache;
  if(buscar)filtrados=filtrados.filter(p=>(p.nombre||'').toLowerCase().includes(buscar)||(p.sku||'').toLowerCase().includes(buscar)||(p.descripcion||'').toLowerCase().includes(buscar));
  if(cat)filtrados=filtrados.filter(p=>p.categoria===cat);
  if(stockF==='ok')filtrados=filtrados.filter(p=>p.stock>(p.stock_minimo||5));
  if(stockF==='bajo')filtrados=filtrados.filter(p=>p.stock>0&&p.stock<=(p.stock_minimo||5));
  if(stockF==='agotado')filtrados=filtrados.filter(p=>p.stock<=0);
  renderTablaInventario(filtrados);
}

