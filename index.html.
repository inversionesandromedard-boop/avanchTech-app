  const m3=pagos.filter(p=>parseInt(p.modelo)===3);

  const detalle={
    total_pagos:pagos.length,
    m1:{
      pagos:m1.length,
      total:m1.reduce((a,p)=>a+parseFloat(p.monto||0),0),
      avanch:m1.reduce((a,p)=>a+parseFloat(p.avanch_parte||0),0),
      komultisoft:m1.reduce((a,p)=>a+parseFloat(p.socio_parte||0),0),
      vicortiz:0
    },
    m2:{
      pagos:m2.length,
      total:m2.reduce((a,p)=>a+parseFloat(p.monto||0),0),
      avanch:m2.reduce((a,p)=>a+parseFloat(p.avanch_parte||0),0),
      komultisoft:m2.reduce((a,p)=>a+parseFloat(p.socio_parte||0),0),
      vicortiz:m2.reduce((a,p)=>a+parseFloat(p.vicortiz_parte||0),0)
    },
    m3:{
      pagos:m3.length,
      total:m3.reduce((a,p)=>a+parseFloat(p.monto||0),0),
      avanch:m3.reduce((a,p)=>a+parseFloat(p.avanch_parte||0),0),
      komultisoft:0,
      vicortiz:0
    }
  };

  const{error}=await sb.from('reportes_corte').insert({
    periodo,fecha_corte:fechaCorte.toISOString().split('T')[0],
    fecha_pago:fechaPago.toISOString().split('T')[0],
    total_recaudado:totalRecaudado,avanch_total:avanchTotal,
    komultisoft_total:komultiTotal,vicortiz_total:vicortizTotal,
    detalle,estado:'pendiente'
  });
  if(error){notif('Error: '+error.message,'err');return;}
  notif('✅ Reporte de corte generado para '+periodo,'ok');
  registrarLog('Reporte de corte generado','pagos','Periodo: '+periodo+' — Total: RD$'+fmt(totalRecaudado));
  cargarReportesCorte();
}

async function cargarReportesCorte(){
  const{data}=await sb.from('reportes_corte').select('*').order('creado_en',{ascending:false});
  if(!data?.length){document.getElementById('t-reportes').querySelector('tbody').innerHTML='<tr><td colspan="9" style="text-align:center;color:var(--muted);padding:18px">Sin reportes</td></tr>';return;}
  document.getElementById('t-reportes').querySelector('tbody').innerHTML=data.map(r=>`<tr>
    <td style="font-weight:600">${r.periodo}</td>
    <td style="color:var(--green3)">RD$${fmt(r.total_recaudado)}</td>
    <td style="color:var(--blue3)">RD$${fmt(r.avanch_total)}</td>
    <td style="color:var(--purple3)">RD$${fmt(r.komultisoft_total)}</td>
    <td style="color:var(--gold3)">RD$${fmt(r.vicortiz_total)}</td>
    <td>${r.fecha_corte}</td>
    <td>${r.fecha_pago}</td>
    <td>${bdg(r.estado)}</td>
    <td><button class="btn btn-primary" style="padding:3px 8px;font-size:10px" onclick="verReporteCorte('${r.id}')">👁️</button> ${r.estado==='pendiente'?`<button class="btn btn-green" style="padding:3px 8px;font-size:10px" onclick="marcarReportePagado('${r.id}')">✓ Pagado</button>`:''}</td>
  </tr>`).join('');
}

async function marcarReportePagado(id){
  const{error}=await sb.from('reportes_corte').update({estado:'pagado'}).eq('id',id);
  if(error){notif('Error','err');return;}
  notif('✅ Reporte marcado como pagado','ok');
  registrarLog('Reporte de corte pagado','pagos','Reporte marcado como pagado','reportes_corte',id);
  cargarReportesCorte();
}

