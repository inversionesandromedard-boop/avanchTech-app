  if(session){usr=session.user;await iniciar();iniciado=true;}
  sb.auth.onAuthStateChange(async(e,s)=>{
    if(e==='SIGNED_IN'&&s){if(iniciado)return;usr=s.user;await iniciar();iniciado=true;}
    else if(e==='SIGNED_OUT'){usr=null;perfil=null;iniciado=false;mostrarAuth();}
  });
};

