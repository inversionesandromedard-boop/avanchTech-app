// ── Importación masiva desde Google Sheets ──
function previsualizarImport(){
  const raw=document.getElementById('import-data').value.trim();
  if(!raw){notif('⚠️ Pega datos primero','err');return;}
  const lineas=raw.split('\n').filter(l=>l.trim());
  _importParsed=lineas.map((linea,i)=>{
    const cols=linea.split('\t');
    return{
      nombre:(cols[0]||'').trim(),
      precio:parseFloat(cols[1])||0,
      stock:parseInt(cols[2])||0,
      categoria:(cols[3]||'otro').trim().toLowerCase(),
      descripcion:(cols[4]||'').trim(),
      imagen_url:(cols[5]||'').trim(),
      sku:(cols[6]||'').trim(),
      costo:parseFloat(cols[7])||0,
      fila:i+1
    };
  }).filter(p=>p.nombre&&p.precio>0);

  const invalidos=lineas.length-_importParsed.length;
  let html='<div style="font-size:12px;margin-bottom:8px"><strong style="color:var(--green3)">'+_importParsed.length+'</strong> productos válidos';
  if(invalidos>0)html+=' · <strong style="color:var(--gold3)">'+invalidos+'</strong> filas ignoradas (sin nombre o precio)';
  html+='</div>';
  html+='<div style="max-height:200px;overflow-y:auto;border:1px solid var(--border);border-radius:8px"><table class="dt" style="font-size:11px"><thead><tr><th>#</th><th>Nombre</th><th>Precio</th><th>Stock</th><th>Cat.</th><th>Imagen</th></tr></thead><tbody>';
  _importParsed.slice(0,15).forEach((p,i)=>{
    html+=`<tr><td>${i+1}</td><td style="font-weight:600">${p.nombre}</td><td style="color:var(--green3)">RD$${fmt(p.precio)}</td><td>${p.stock}</td><td>${p.categoria}</td><td>${p.imagen_url?'✓ URL':'—'}</td></tr>`;
  });
  if(_importParsed.length>15)html+='<tr><td colspan="6" style="text-align:center;color:var(--muted)">... y '+(_importParsed.length-15)+' más</td></tr>';
  html+='</tbody></table></div>';
  document.getElementById('import-preview').innerHTML=html;
  document.getElementById('import-preview').style.display='block';
  document.getElementById('btn-import-exec').style.display='inline-flex';
}

async function ejecutarImport(){
  if(!_importParsed.length){notif('Nada que importar','err');return;}
  const total=_importParsed.length;
  const prog=document.getElementById('import-progress');
  const bar=document.getElementById('import-bar');
  const log=document.getElementById('import-log');
  prog.style.display='block';
  document.getElementById('btn-import-exec').disabled=true;

  let ok=0,err=0;
  for(let i=0;i<total;i++){
    const p=_importParsed[i];
    bar.style.width=Math.round(((i+1)/total)*100)+'%';
    log.textContent='Importando '+(i+1)+'/'+total+': '+p.nombre+'...';

    const datos={
      nombre:p.nombre,precio:p.precio,stock:p.stock,
      categoria:['tecnologia','accesorio','servicio','software','equipos','repuestos','otro'].includes(p.categoria)?p.categoria:'otro',
      descripcion:p.descripcion||null,imagen_url:p.imagen_url||null,
      sku:p.sku||null,costo:p.costo||0,
      stock_minimo:5,estado:'activo',publicado_tienda:true
    };
    const{error}=await sb.from('productos').insert(datos);
    if(error){err++;log.textContent='❌ Error en "'+p.nombre+'": '+error.message;}
    else{ok++;}
  }

  bar.style.width='100%';bar.style.background='var(--green)';
  log.innerHTML='<strong style="color:var(--green3)">✓ Importación completa:</strong> '+ok+' productos importados'+(err?' · '+err+' errores':'');
  document.getElementById('btn-import-exec').disabled=false;
  registrarLog('Importación masiva','inventario',ok+' productos importados desde Google Sheets');
  notif('✓ '+ok+' productos importados','ok');
  cargarInventario();
}

// ── Descuento automático de stock ──
async function descontarStockPedido(pedidoId){
  const{data:pedido}=await sb.from('pedidos').select('*').eq('id',pedidoId).single();
  if(!pedido?.items)return;
  let items=[];
  try{items=typeof pedido.items==='string'?JSON.parse(pedido.items):pedido.items;}catch(e){return;}
  if(!Array.isArray(items))return;
  for(const item of items){
    if(!item.producto_id||!item.cantidad)continue;
    const{data:prod}=await sb.from('productos').select('stock,nombre').eq('id',item.producto_id).single();
    if(!prod)continue;
    const nuevoStock=Math.max(0,(prod.stock||0)-parseInt(item.cantidad));
    await sb.from('productos').update({stock:nuevoStock}).eq('id',item.producto_id);
    await sb.from('movimientos_stock').insert({producto_id:item.producto_id,tipo:'salida',cantidad:parseInt(item.cantidad),stock_resultante:nuevoStock,detalle:'Venta — Pedido #'+pedidoId.slice(-6)+' — '+(pedido.cliente_nombre||'')});
  }
}

