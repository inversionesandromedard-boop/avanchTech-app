async function guardarProducto(){
  const id=document.getElementById('prod-id').value;
  const nombre=document.getElementById('prod-nombre').value.trim();
  const precio=parseFloat(document.getElementById('prod-precio').value)||0;
  const stock=parseInt(document.getElementById('prod-stock').value)||0;
  if(!nombre||!precio){notif('⚠️ Nombre y precio requeridos','err');return;}

  // Parsear especificaciones a JSON
  const specsRaw=document.getElementById('prod-specs').value.trim();
  let specs=null;
  if(specsRaw){
    specs={};
    specsRaw.split('\n').forEach(line=>{
      const parts=line.split(':');
      if(parts.length>=2)specs[parts[0].trim()]=parts.slice(1).join(':').trim();
    });
  }

  const datos={
    nombre,
    sku:document.getElementById('prod-sku').value.trim()||null,
    categoria:document.getElementById('prod-cat').value,
    estado:document.getElementById('prod-estado').value,
    precio,
    costo:parseFloat(document.getElementById('prod-costo').value)||0,
    stock,
    stock_minimo:parseInt(document.getElementById('prod-stock-min').value)||5,
    descripcion:document.getElementById('prod-desc').value.trim()||null,
    especificaciones:specs,
    imagen_url:document.getElementById('prod-img').value.trim()||null,
    publicado_tienda:document.getElementById('prod-tienda').checked
  };

  if(id){
    const{data:prev}=await sb.from('productos').select('stock').eq('id',id).single();
    const{error}=await sb.from('productos').update({...datos,actualizado_en:new Date().toISOString()}).eq('id',id);
    if(error){notif('Error: '+error.message,'err');return;}
    if(prev&&prev.stock!==stock){
      const diff=stock-prev.stock;
      await sb.from('movimientos_stock').insert({producto_id:id,tipo:diff>0?'entrada':'ajuste',cantidad:Math.abs(diff),stock_resultante:stock,detalle:'Edición manual — stock: '+prev.stock+' → '+stock});
    }
    notif('✓ Producto actualizado','ok');
    registrarLog('Producto editado','inventario','Producto: '+nombre,'productos',id);
  } else {
    const{data:nuevo,error}=await sb.from('productos').insert(datos).select().single();
    if(error){notif('Error: '+error.message,'err');return;}
    if(stock>0){
      await sb.from('movimientos_stock').insert({producto_id:nuevo.id,tipo:'entrada',cantidad:stock,stock_resultante:stock,detalle:'Stock inicial'});
    }
    notif('✓ Producto creado','ok');
    registrarLog('Producto creado','inventario',nombre+' — Stock:'+stock+' — RD$'+fmt(precio),'productos');
  }
  limpiarFormProd();tog('form-prod');cargarInventario();
}

