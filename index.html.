function cargarTopClientes(facturas){
  const clientes={};
  facturas.forEach(f=>{
    const nom=f.clientes?.nombre||'Sin nombre';
    if(!clientes[nom])clientes[nom]={facturado:0,pagado:0,pendiente:0};
    const m=parseFloat(f.monto_rd||0);
    clientes[nom].facturado+=m;
    if(f.estado==='pagada')clientes[nom].pagado+=m;
    else clientes[nom].pendiente+=m;
  });
  const sorted=Object.entries(clientes).sort((a,b)=>b[1].facturado-a[1].facturado).slice(0,5);
  if(!sorted.length){tbEmpty('t-top-clientes',4);return;}
