async function iniciar(){
  const{data:p,error:perr}=await sb.from('perfiles').select('*').eq('id',usr.id).single();
  if(perr||!p){
    const nombre=usr.user_metadata?.nombre||usr.email.split('@')[0];
    await sb.from('perfiles').upsert({id:usr.id,nombre,email:usr.email,rol:'cliente'},{onConflict:'id',ignoreDuplicates:true});
    const{data:p2}=await sb.from('perfiles').select('*').eq('id',usr.id).single();
    perfil=p2||{id:usr.id,nombre,email:usr.email,rol:'cliente'};
  } else { perfil=p; }

  const{data:cf}=await sb.from('config_fondo').select('*').eq('activo',true).single();
  fondoConfig=cf||{tasa_rendimiento_anual:15,tasa_inversionista_anual:7,spread_avanch:8,techo_ganancia:22470,max_exposicion_pct:30,reserva_liquidez_pct:20,penalizacion_retiro_pct:5,plazo_minimo_meses:1,salario_minimo:21000};

  document.getElementById('auth-screen').style.display='none';
  document.getElementById('app-shell').classList.add('visible');
  document.getElementById('tb-user').textContent=perfil.nombre||usr.email;
  document.getElementById('tb-rol').textContent=perfil.rol;
  actualizarReglasUI();generarNav();cargarInicio();
  registrarLog('Login exitoso','auth','Inicio de sesión — rol: '+perfil.rol);
  registrarSesion();
  sb.from('perfiles').update({ultimo_login:new Date().toISOString()}).eq('id',usr.id).then(()=>{});
  document.getElementById('p-nombre').value=perfil.nombre||'';
  document.getElementById('p-email').value=perfil.email||usr.email;
  document.getElementById('p-tel').value=perfil.telefono||'';
  document.getElementById('p-rnc').value=perfil.rnc||'';
}

